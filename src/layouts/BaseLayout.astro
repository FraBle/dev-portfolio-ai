---
import type { PortfolioConfig } from "../types";
import "../styles/global.css";

interface Props {
	title: string;
	config: PortfolioConfig;
	description?: string;
	noindex?: boolean;
}

const { title, config, description, noindex } = Astro.props;

const desc = description || config.description;
const theme = config.theme || "default";
const siteUrl = config.site || "";
const ogImage = config.openGraph?.image ? new URL(config.openGraph.image, siteUrl).href : "";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title>{title}</title>
		<meta name="description" content={desc} />
		<meta name="viewport" content="width=device-width" />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		{config.openGraph?.image && <link rel="preload" as="image" href={config.openGraph.image} />}

		<meta property="og:url" content={siteUrl} />
		<meta property="og:type" content={config.openGraph?.type || "website"} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={desc} />
		<meta property="og:image" content={ogImage} />
		{config.openGraph?.locale && <meta property="og:locale" content={config.openGraph.locale} />}
		{config.openGraph?.siteName && <meta property="og:site_name" content={config.openGraph.siteName} />}

		<meta name="twitter:card" content={config.twitter?.card || "summary_large_image"} />
		{siteUrl && <meta property="twitter:domain" content={siteUrl.split("//")[1] ?? ""} />}
		<meta property="twitter:url" content={siteUrl} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={desc} />
		<meta name="twitter:image" content={ogImage} />
		{config.twitter?.creator && <meta name="twitter:creator" content={config.twitter.creator} />}

		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Itim" />

		{config.socialProfiles?.map((url) => (
			<link rel="me" href={url} />
		))}

		<!-- I'm Vengeance -->
	</head>
	<body data-theme={theme} class="relative bg-skin-fill">
		<div class="absolute top-0 -z-10 h-full w-full print:hidden">
			<div class="bg-skin-hue/10 absolute bottom-auto left-[20%] right-auto top-0 h-[200px] w-[200px] -translate-x-[30%] translate-y-[20%] rounded-full blur-[80px] invert-0 dark:bg-white/5"></div>
		</div>
		<slot />
		<!-- Base resets are in global.css @layer base -->

		<script>
			import Alpine from "alpinejs";
			import collapse from "@alpinejs/collapse";

			Alpine.plugin(collapse);

			Alpine.data("themeSelector", () => ({
				open: false,
				currentTheme: "system",
				themes: [
					{ value: "system", label: "System", icon: "computer" },
					{ value: "light", label: "Light", icon: "sun" },
					{ value: "dark", label: "Dark", icon: "moon" },
				],

				init() {
					const savedTheme = localStorage.getItem("theme");
					this.currentTheme = savedTheme || "system";
					this.applyTheme(this.currentTheme);

					window
						.matchMedia("(prefers-color-scheme: dark)")
						.addEventListener("change", () => {
							if (this.currentTheme === "system") {
								this.applyTheme("system");
							}
						});
				},

				selectTheme(value: string) {
					this.currentTheme = value;
					this.applyTheme(value);
					localStorage.setItem("theme", value);
					this.open = false;
				},

				applyTheme(value: string) {
					const systemTheme = window.matchMedia("(prefers-color-scheme: dark)")
						.matches
						? "dark"
						: "light";
					const theme = value === "system" ? systemTheme : value;
					document.documentElement.classList.remove("light", "dark");
					document.documentElement.classList.add(theme);
				},
			}));

			Alpine.start();
		</script>
	</body>
</html>
