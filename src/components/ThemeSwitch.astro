---
---

<div class="no-print inline-flex items-center gap-2" x-data="themeSelector()" x-init="init()" role="radiogroup" aria-label="Theme">
	<button
		type="button"
		title="Light theme"
		class="flex h-8 w-8 cursor-pointer items-center justify-center rounded-full text-skin-muted transition-all duration-200 hover:text-skin-base"
		:class="currentTheme === 'light' ? 'ring-2 ring-skin-hue text-skin-hue' : ''"
		@click="selectTheme('light')"
		role="radio"
		:aria-checked="currentTheme === 'light'"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="12" cy="12" r="4"></circle>
			<path d="M12 2v2"></path>
			<path d="M12 20v2"></path>
			<path d="m4.93 4.93 1.41 1.41"></path>
			<path d="m17.66 17.66 1.41 1.41"></path>
			<path d="M2 12h2"></path>
			<path d="M20 12h2"></path>
			<path d="m6.34 17.66-1.41 1.41"></path>
			<path d="m19.07 4.93-1.41 1.41"></path>
		</svg>
	</button>
	<button
		type="button"
		title="Dark theme"
		class="flex h-8 w-8 cursor-pointer items-center justify-center rounded-full text-skin-muted transition-all duration-200 hover:text-skin-base"
		:class="currentTheme === 'dark' ? 'ring-2 ring-skin-hue text-skin-hue' : ''"
		@click="selectTheme('dark')"
		role="radio"
		:aria-checked="currentTheme === 'dark'"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
		</svg>
	</button>
	<button
		type="button"
		title="System theme"
		class="flex h-8 w-8 cursor-pointer items-center justify-center rounded-full text-skin-muted transition-all duration-200 hover:text-skin-base"
		:class="currentTheme === 'system' ? 'ring-2 ring-skin-hue text-skin-hue' : ''"
		@click="selectTheme('system')"
		role="radio"
		:aria-checked="currentTheme === 'system'"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<rect width="20" height="14" x="2" y="3" rx="2"></rect>
			<line x1="8" x2="16" y1="21" y2="21"></line>
			<line x1="12" x2="12" y1="17" y2="21"></line>
		</svg>
	</button>
</div>

<style>
	:global(.dark) {
		color-scheme: dark;
	}

	[x-cloak] {
		display: none !important;
	}
</style>
